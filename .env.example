# Variables de entorno para Pinata

# JWT de autenticación de Pinata (obtener de https://app.pinata.cloud/developers/keys)
PINATA_JWT=tu_jwt_aqui

# URL del Gateway de Pinata
GATEWAY_URL=https://pinata-server.pinata-server.workers.dev/presigned_url

# ─── Blockchain / Wallet Auto-Custodia ────────────────────────────────────────

# URL del nodo RPC de Somnia Network
RPC_URL=https://dream-rpc.somnia.network

# Clave privada de la wallet auto-custodia (64 caracteres hex, SIN 0x)
# NUNCA subir al repositorio – solo en .env local o Key Vault en producción
PRIVATE_KEY=tu_clave_privada_de_64_caracteres

# Dirección del contrato NFT desplegado
CONTRACT_ADDRESS=0xE16EcfeE6067B4918AF3eAF09Dd134FFdaE92D4D
